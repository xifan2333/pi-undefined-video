{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "types": ["node"],
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "extensions/**/*.ts", "bin/**/*.mjs"],
  "exclude": ["node_modules", "archive"]
}
